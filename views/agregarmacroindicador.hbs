<main>
<section class="agregar-section section">
    <div class="agregar-pais-contenedor">
        <div class="form-inner">
            <h2 class="mb-4">Crear macroindicador</h2>

            {{#if errores}}
            <div class="alert alert-danger">
                {{#each errores}}<p class="mb-0">{{this}}</p>{{/each}}
            </div>
            {{/if}}

            <form action="/macroindicadores/crear" method="POST">
                <div class="mb-3 form-group">
                    <label class="form-label">Nombre del macroindicador</label>
                    <input type="text" name="nombre" class="form-control nombre-pais-input" placeholder="Ej: Crecimiento del PIB" value="{{datos.nombre}}">
                </div>
                <div class="mb-3 form-group">
                    <label class="form-label">Peso (decimal, ej: 0.3)</label>
                    <input type="number" name="peso" class="form-control nombre-pais-input" step="0.001" min="0" max="1" placeholder="0.30" value="{{datos.peso}}">
                </div>
                <div class="mb-3 form-group">
                    <label class="form-label">¿Es mejor más alto?</label>
                    <select name="esMejorMasAlto" class="form-select nombre-pais-input">
                        <option value="true" {{#if (eq datos.esMejorMasAlto "true")}}selected{{/if}}>Sí</option>
                        <option value="false" {{#if (eq datos.esMejorMasAlto "false")}}selected{{/if}}>No</option>
                    </select>
                </div>
                <div class="botonos-contenedore">
                    <button class="btn btn-success btn-crear" type="submit">Crear macroindicador</button>
                    <a href="/macroindicadores"><button type="button" class="btn btn-warning btn-volver">Volver atrás</button></a>
                </div>
            </form>
        </div>
    </div>
</section>
</main>
