<main>
<section class="seccion-paises container mt-4">
    <h2>Macroindicadores</h2>

    {{#unless sumaCompleta}}
    <a href="/macroindicadores/crear"><button type="button" class="btn btn-success agregar-paises mb-3">+ Crear macroindicador</button></a>
    {{else}}
    <button type="button" class="btn btn-secondary mb-3 disabled" title="La suma de pesos ya es igual a 1">+ Crear macroindicador</button>
    {{/unless}}

    <div class="tabla-conteneedor">
        <table class="tabla-paises">
            <thead>
                <tr>
                    <th>Nombre</th>
                    <th>Peso</th>
                    <th>¿Mejor más alto?</th>
                    <th class="accion-label">Acciones</th>
                </tr>
            </thead>
            <tbody>
                {{#each macroindicadores}}
                <tr>
                    <td>{{nombre}}</td>
                    <td>{{peso}}</td>
                    <td class="si-no-td"><div class="si-no">{{#if esMejorMasAlto}}Sí{{else}}No{{/if}}</div></td>
                    <td class="accion-btn">
                        <a href="/macroindicadores/editar/{{id}}"><button type="button" class="btn btn-warning btn-editar">Editar</button></a>
                        <a href="/macroindicadores/eliminar/{{id}}"><button type="button" class="btn btn-danger btn-elimnar">Eliminar</button></a>
                    </td>
                </tr>
                {{else}}
                <tr><td colspan="4" class="text-center text-muted">No hay macroindicadores registrados.</td></tr>
                {{/each}}
            </tbody>
        </table>
    </div>
</section>
</main>
